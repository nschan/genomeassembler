    test("ASSEMBLE - single strategy with flye ONT") {

        when {
            params {
                outdir = "output"
            }
            workflow {
                """
                // Create test input channel for single strategy with flye ONT
                input[0] = Channel.of([
                    [
                        meta: [
                            id: 'test_sample',
                            assembly: false,
                            strategy: 'single',
                            assembler_ont: 'flye',
                            ontreads: file("\${projectDir}/tests/data/ont_reads.fastq.gz"),
                            hifireads: null,
                            quast: false,
                            use_ref: false,
                            lift_annotations: false
                        ]
                    ]
                ])
                // meryl_kmers channel (empty for this test)
                input[1] = Channel.empty()
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() > 0
        }
    }

